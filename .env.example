# Google Maps (browser — restrict by HTTP referrer in Google Cloud Console)
# Was AZ_GOOGLE_MAPS_API_KEY in WordPress wp-config.php
#
# Required APIs: Maps JavaScript API (+ Directions API for travel driving route)
# Referrers to allow (Application restrictions → HTTP referrers):
#   http://localhost:4321/*
#   http://127.0.0.1:4321/*
#   https://annaandzach.love/*
#   https://www.annaandzach.love/*
#   https://anna-zach-wedding-production.up.railway.app/*  (Railway preview URL)
#   https://dev.annaandzach.love/*
# (WordPress local MAMP used http://localhost:8888/* — add 4321 for Astro dev)
PUBLIC_GOOGLE_MAPS_API_KEY=

# RSVP backend (server-only — was define() in wp-config.php)
AZ_TELEGRAM_BOT_TOKEN=
AZ_TELEGRAM_CHAT_ID=
AZ_SHEETS_WEBHOOK_URL=
AZ_SHEETS_SECRET=

# RSVP confirmation email (Resend — https://resend.com/api-keys)
# Without these, Telegram + Sheets still work; guests just won't get an auto-reply.
# Dev/testing: use onboarding@resend.dev as FROM (Resend only delivers to your account email).
# Production: verify annaandzach.love in Resend, then e.g. Anna & Zach <rsvp@annaandzach.love>
AZ_RESEND_API_KEY=
AZ_RSVP_EMAIL_FROM=
AZ_RSVP_REPLY_TO=
AZ_SITE_URL=https://annaandzach.love
