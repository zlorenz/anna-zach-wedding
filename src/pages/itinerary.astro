---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageBreakTriptych from '../components/ImageBreakTriptych.astro';
import { itineraryData, siteData, homeData, decodeEntities, formatItineraryDayDate } from '../lib/content';

const { introHtml, weddingDay, multiDay } = itineraryData;
---

<BaseLayout title={`Itinerary · ${siteData.name}`} bodyClass="page-itinerary">
  {
    introHtml && (
      <section class="az-section az-itinerary-page__intro">
        <div class="container az-page-width">
          <div class="row">
            <div class="col-lg-10">
              <div class="az-prose" set:html={introHtml} />
            </div>
          </div>
        </div>
      </section>
    )
  }

  {
    weddingDay.length > 0 && (
      <section class="az-section az-itinerary-page__section az-itinerary-page__section--wedding-day">
        <div class="container az-page-width">
          <div class="row">
            <div class="col-12">
              <header class="az-itinerary-page__heading">
                <h1 class="az-page-title az-page-title--plain">Wedding Day</h1>
                <p class="az-itinerary-page__wedding-date">{formatItineraryDayDate(homeData.eventDate)}</p>
              </header>
              <div class="az-itinerary-timeline" role="list">
                {
                  weddingDay.map((event) => (
                    <article
                      class:list={[
                        'az-itinerary-event',
                        'az-itinerary-event--timeline',
                        event.typeClass && `az-itinerary-event--type-${event.typeClass}`,
                        event.featured && 'az-itinerary-event--featured',
                      ]}
                      role="listitem"
                    >
                      <div class="az-itinerary-event__time">{event.time}</div>
                      <div class="az-itinerary-event__content">
                        <h3 class="az-itinerary-event__title">{decodeEntities(event.title)}</h3>
                        {event.descriptionHtml && (
                          <div class="az-itinerary-event__description" set:html={event.descriptionHtml} />
                        )}
                        {event.location && <div class="az-itinerary-event__location">{decodeEntities(event.location)}</div>}
                      </div>
                    </article>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  {
    weddingDay.length > 0 && multiDay.length > 0 && (
      <ImageBreakTriptych
        class="az-itinerary-image-break az-travel__section--image-breaks"
        ariaLabel="Itinerary image highlights"
        leftSlot="itinerary.dividerLeft"
        centerSlot="itinerary.dividerCenter"
        rightSlot="itinerary.dividerRight"
      />
    )
  }

  {
    multiDay.length > 0 && (
      <section
        class="az-section az-section--dark az-itinerary-page__section az-itinerary-page__section--multi-day"
      >
        <div class="container az-page-width">
          <div class="row">
            <div class="col-lg-10">
              <h2 class="az-page-title az-page-title--plain">Weekend Schedule</h2>
              <div class="az-itinerary-days">
                {
                  multiDay.map((day) => (
                    <section class:list={['az-itinerary-day', day.highlight && 'az-itinerary-day--highlight']}>
                      {day.date && (
                        <header class="az-itinerary-day__header">
                          {day.highlight && (
                            <p class="az-itinerary-day__eyebrow">Wedding day</p>
                          )}
                          <h3 class="az-itinerary-day__date">{formatItineraryDayDate(day.date)}</h3>
                        </header>
                      )}
                      {day.descriptionHtml && (
                        <div class="az-itinerary-day__description" set:html={day.descriptionHtml} />
                      )}
                      {day.events.length > 0 && (
                        <ol class="az-itinerary-events">
                          {
                            day.events.map((event) => (
                              <li class="az-itinerary-events__item">
                                <article
                                  class:list={[
                                    'az-itinerary-event',
                                    'az-itinerary-event--multi',
                                    event.typeClass && `az-itinerary-event--type-${event.typeClass}`,
                                  ]}
                                >
                                  <div class="az-itinerary-event__time">{event.time}</div>
                                  <div class="az-itinerary-event__body">
                                    <h4 class="az-itinerary-event__title">{decodeEntities(event.title)}</h4>
                                    {event.descriptionHtml && (
                                      <div class="az-itinerary-event__description" set:html={event.descriptionHtml} />
                                    )}
                                    {event.externalUrl && (
                                      <a
                                        class="az-itinerary-event__external-link"
                                        href={event.externalUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                      >
                                        {event.externalLabel || 'View Details'}
                                      </a>
                                    )}
                                  </div>
                                </article>
                              </li>
                            ))
                          }
                        </ol>
                      )}
                    </section>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <script slot="scripts" src="/assets/js/travel-parallax.js" defer></script>
</BaseLayout>
