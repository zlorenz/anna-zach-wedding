---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ImageBreakTriptych from '../components/ImageBreakTriptych.astro';
import ImageBreakOffset from '../components/ImageBreakOffset.astro';
import AzIcon from '../components/AzIcon.astro';
import { travelData, siteData } from '../lib/content';

const { airport, transfer, essentials } = travelData;
const mapConfig = travelData.mapConfig;
const mapsApi = Boolean(mapConfig?.airport || mapConfig?.route);
---

<BaseLayout
  title={`Travel · ${siteData.name}`}
  bodyClass="page-travel"
  mapsApi={mapsApi}
  mapsCallback="azTravelMapInit"
>
  <section
    class="az-travel az-travel__section az-travel__section--airport"
    aria-labelledby="az-travel-airport-title"
  >
    <div class="container">
      <div class="row align-items-start align-items-lg-center gy-4 gx-lg-5 az-travel-airport__editorial">
        <div class="col-lg-7 az-travel-airport__copy">
          <header class="az-travel-airport__header">
            <h1 id="az-travel-airport-title" class="az-travel-airport__heading">
              <span class="az-travel-airport__title-mobile az-page-title az-page-title--plain">
                {airport.titleLines.join(' ')}
              </span>
              <span class="az-travel-airport__title-desktop">
                {
                  airport.titleLines.map((line) => (
                    <span class="az-travel-airport__display-line">{line}</span>
                  ))
                }
              </span>
            </h1>
            <div class="az-travel-airport__lead az-prose">
              <div class="az-travel-airport__rule" aria-hidden="true">
                <span class="az-travel-airport__rule-line"></span>
                <span class="az-travel-airport__rule-icon">
                  <AzIcon name="plane" />
                </span>
              </div>
              <div set:html={airport.leadHtml} />
            </div>
          </header>
        </div>
        <div class="col-lg-5 az-travel-airport__media">
          <div class="az-travel-airport__map-frame az-travel-airport__map-frame--api">
            <div
              id="az-travel-airport-map-canvas"
              class="az-travel-airport__map-canvas"
              role="img"
              aria-label="Airport location map"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ImageBreakTriptych
    class="az-travel az-travel__section az-travel__section--image-breaks az-travel__section--image-breaks-top"
    ariaLabel="Travel image highlights"
    containerClass="container-fluid az-page-width"
    rowClass="row g-3 g-lg-4 az-travel-image-break__triptych align-items-center"
    mobileColumns={2}
    leftSlot="travel.triptychLeft"
    centerSlot="travel.triptychCenter"
    rightSlot="travel.triptychRight"
  />

  <section
    class="az-travel az-travel__section az-travel__section--transfer"
    aria-labelledby="az-travel-transfer-title"
  >
    <div class="container az-page-width">
      <div class="row align-items-center gy-4 gx-lg-5 az-travel-transfer__row">
        <div class="col-lg-5 az-travel-transfer__map-col">
          <div class="az-travel__embed az-travel__embed--route-api">
            <div
              id="az-travel-route-map-canvas"
              class="az-travel__route-map-canvas"
              role="img"
              aria-label="Driving route from airport to Nha Trang"
            ></div>
            <p class="az-travel__route-error" id="az-travel-route-error" role="alert" hidden></p>
          </div>
        </div>
        <div class="col-lg-7 az-travel-transfer__copy-col">
          <header class="az-travel__header az-travel-transfer__header">
            <h2 id="az-travel-transfer-title" class="az-travel__title">{transfer.title}</h2>
          </header>
          <div
            class="az-travel__body az-travel__intro az-prose az-travel-transfer__body"
            set:html={transfer.bodyHtml}
          />
        </div>
      </div>
    </div>
  </section>

  <ImageBreakOffset
    smallSlot="travel.offsetSmall"
    largeSlot="travel.offsetLarge"
    mobileSlot="travel.offsetMobile"
  />

  <section
    class="az-travel az-travel__section az-travel__section--essentials az-section--dark"
    aria-labelledby="az-travel-essentials-title"
  >
    <div class="container az-page-width">
      <header class="az-travel-essentials__header">
        <p class="az-travel-essentials__eyebrow mb-0">{essentials.eyebrow}</p>
        <h2 id="az-travel-essentials-title" class="az-travel-essentials__title mb-0">
          {essentials.title}
        </h2>
      </header>

      <div class="row gy-4 gx-lg-5 align-items-center az-travel-essentials__visa-row">
        <div class="col-lg-8 az-travel-essentials__visa-content">
          <header class="az-travel__header">
            <h3 id="az-travel-visa-title" class="az-travel__title">{essentials.visa.title}</h3>
            <div
              class="az-travel__intro az-prose az-travel-essentials__copy"
              set:html={essentials.visa.bodyHtml}
            />
          </header>
          <p class="az-travel__actions mb-0">
            <a
              class="az-travel__button az-travel__button--outline-light"
              href={essentials.visa.buttonUrl}
              rel="noopener noreferrer"
              target="_blank"
            >
              {essentials.visa.buttonLabel}
            </a>
          </p>
        </div>
        <div class="col-lg-4 az-travel-essentials__visa-aside">
          <aside class="az-travel-callout az-travel-callout--tip">
            <p class="az-travel-callout__icon mb-0" aria-hidden="true">
              {essentials.visa.callout.icon === 'plane' && <AzIcon name="plane" />}
            </p>
            <h4 class="az-travel-callout__title mb-0">{essentials.visa.callout.title}</h4>
            <p class="az-travel-callout__body mb-0">{essentials.visa.callout.body}</p>
          </aside>
        </div>
      </div>

      <div class="row gy-4 gx-lg-5 az-travel-essentials__sim-row" data-az-travel-module="sim-payment">
        <div class="col-lg-6 order-lg-2 az-travel-essentials__sim-col">
          <header class="az-travel__header">
            <h3 id="az-travel-sim-title" class="az-travel__title az-travel-essentials__column-title">
              {essentials.sim.title}
            </h3>
          </header>
          <div
            class="az-travel__intro az-prose az-travel-essentials__copy"
            set:html={essentials.sim.bodyHtml}
          />
          <p class="az-travel__actions mb-0">
            <a
              class="az-travel__button az-travel__button--outline-light"
              href={essentials.sim.buttonUrl}
              rel="noopener noreferrer"
              target="_blank"
            >
              {essentials.sim.buttonLabel}
            </a>
          </p>
        </div>
        <div class="col-lg-6 order-lg-1 az-travel-essentials__currency-col">
          <header class="az-travel__header">
            <h3 id="az-travel-currency-title" class="az-travel__title az-travel-essentials__column-title">
              {essentials.currency.title}
            </h3>
          </header>
          <div
            class="az-travel__intro az-prose az-travel-essentials__copy"
            set:html={essentials.currency.bodyHtml}
          />
          <aside class="az-travel-callout az-travel-callout--exchange">
            <p class="az-travel-callout__label mb-0">{essentials.currency.exchangeLabel}</p>
            <p class="az-travel-callout__value mb-0">{essentials.currency.exchangeValue}</p>
          </aside>
        </div>
      </div>
    </div>
  </section>

  {
    mapConfig && (
      <script slot="scripts" define:vars={{ mapConfig }}>
        window.azTravelMap = mapConfig;
      </script>
    )
  }
  <script slot="scripts" src="/assets/js/travel-map.js"></script>
  <script slot="scripts" src="/assets/js/travel-parallax.js" defer></script>
</BaseLayout>
