---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import AccommodationMapSection from '../components/AccommodationMapSection.astro';
import ImageBreakTriptych from '../components/ImageBreakTriptych.astro';
import { accommodationData, siteData } from '../lib/content';

const { intro, featured, picks, airbnb } = accommodationData;
const mapConfig = accommodationData.mapConfig;
const mapsApi = Boolean(mapConfig?.places?.length);
---

<BaseLayout
  title={`Accommodation · ${siteData.name}`}
  bodyClass="page-accommodation"
  mapsApi={mapsApi}
  mapsCallback="azAccommodationMapInit"
>
  <section class="az-section az-accommodation-intro">
    <div class="container az-page-width">
      <div class="row">
        <div class="col-lg-8">
          <h1 class="az-accommodation-page-title">{intro.pageTitle}</h1>
          <div class="az-prose az-accommodation-intro__copy">
            <p>{intro.copy}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="az-section az-accommodation-featured" aria-labelledby="az-accommodation-featured-title">
    <div class="container az-page-width">
      <p class="az-accommodation-eyebrow">{featured.eyebrow}</p>
      <div class="az-accommodation-featured__card card">
        <div class="card-body p-4 p-lg-5">
          <div class="row g-4 align-items-start">
            <div class="col-lg-8">
              <h2 id="az-accommodation-featured-title" class="h3 mb-3">{featured.title}</h2>
              <p class="lead az-accommodation-featured__tagline mb-3">{featured.tagline}</p>
              <ul class="az-accommodation-featured__reasons">
                {featured.reasons.map((reason) => <li>{reason}</li>)}
              </ul>
            </div>
            <div class="col-lg-4">
              <div class="az-accommodation-featured__aside">
                <a
                  class="btn btn-primary w-100 mb-3"
                  href={featured.bookUrl}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {featured.bookLabel}
                </a>
                <div class="az-accommodation-note az-accommodation-note--compact">
                  {featured.note}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="az-section az-accommodation-picks" aria-labelledby="az-accommodation-picks-title">
    <div class="container az-page-width">
      <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
        <h2 id="az-accommodation-picks-title" class="mb-0">{picks.title}</h2>
      </div>
      <div class="row g-3">
        {
          picks.hotels.map((hotel) => (
            <div class="col-md-6 col-xl-3">
              <article class="card h-100 az-accommodation-pick-card">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                  <h3 class="h4 mb-1">{hotel.title}</h3>
                  <p class="small mb-3 flex-grow-1">{hotel.blurb}</p>
                  <div class="az-accommodation-pick-card__meta-row d-flex align-items-center gap-2 mb-2">
                    <a
                      class="btn btn-outline-dark btn-sm az-accommodation-pick-card__link"
                      href={hotel.url}
                      rel="noopener noreferrer"
                      target="_blank"
                    >
                      View hotel
                    </a>
                    {hotel.pricing && (
                      <span class="az-accommodation-pick-card__tier small text-muted mb-0">
                        {hotel.pricing}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="az-section az-accommodation-airbnb pt-0">
    <div class="container az-page-width">
      <div class="row">
        <div class="col-lg-8">
          <div class="az-accommodation-note">
            <h2 class="h6 text-uppercase letter-spacing text-muted mb-2">{airbnb.heading}</h2>
            <div class="az-prose az-accommodation-note__body">
              <p>{airbnb.copy}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ImageBreakTriptych
    class="az-accommodation-image-break az-section--image-breaks-offset"
    ariaLabel="Accommodation image highlights"
    centerColumnClass="col-md-6"
    sideColumnClass="col-md-3"
    leftSlot="accommodation.dividerLeft"
    centerSlot="accommodation.dividerCenter"
    rightSlot="accommodation.dividerRight"
  />

  <AccommodationMapSection />
  {
    mapConfig && (
      <script slot="scripts" define:vars={{ mapConfig }}>
        window.azAccommodationMap = mapConfig;
      </script>
    )
  }
  <script slot="scripts" src="/assets/js/accommodation-map.js"></script>
  <script slot="scripts" src="/assets/js/travel-parallax.js" defer></script>
</BaseLayout>
