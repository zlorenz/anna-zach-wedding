---
import '../styles/style.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AzIcon from '../components/AzIcon.astro';
import { getContent, getUi } from '../lib/content';
import { getGoogleMapsApiKey } from '../lib/env';
import { localeLang, type Locale } from '../lib/i18n';

interface Props {
  title?: string;
  /** Short blurb for link previews (iMessage, Slack, etc.) */
  description?: string;
  bodyClass?: string;
  isHome?: boolean;
  /** Load Google Maps JS API (requires PUBLIC_GOOGLE_MAPS_API_KEY) */
  mapsApi?: boolean;
  /** Global callback defined by page map script, e.g. azTravelMapInit */
  mapsCallback?: string;
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'en';
const { site, home } = getContent(locale);
const ui = getUi(locale);

const {
  title = site.name,
  description = ui.metaDescription
    .replace('{name}', site.name)
    .replace('{date}', home.eventDate)
    .replace('{location}', home.eventLocation),
  bodyClass = '',
  isHome = false,
  mapsApi = false,
  mapsCallback = '',
} = Astro.props;

const mapsKey = getGoogleMapsApiKey();
const siteOrigin = site.siteUrl.replace(/\/$/, '');
const pageUrl = `${siteOrigin}${Astro.url.pathname}`;
const shareImageUrl = new URL(site.shareImage, `${siteOrigin}/`).href;
const htmlLang = localeLang(locale);
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={site.themeColor} />
    <link rel="icon" href={site.favicon} type="image/png" />
    <link rel="apple-touch-icon" href={site.favicon} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={shareImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImageUrl} />
    <link rel="stylesheet" href="https://use.typekit.net/hvt3dwm.css" />
    {
      locale === 'ru' && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap"
            rel="stylesheet"
          />
        </>
      )
    }
    <link rel="stylesheet" href="/assets/fonts/remsen-script/remsen-script.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
  </head>
  <body class:list={[bodyClass, isHome && 'home', !isHome && 'az-inner-page']}>
    <a href="#az-main" class="visually-hidden-focusable">{ui.skipToContent}</a>
    <div id="az-site">
      <Header isHome={isHome} locale={locale} />
      <main id="az-main">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
    <button
      type="button"
      class="az-back-to-top"
      data-az-back-to-top
      aria-label={ui.backToTop}
      aria-hidden="true"
      tabindex="-1"
    >
      <AzIcon name="arrow-up" />
    </button>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/assets/js/nav-scroll.js" defer></script>
    <script src="/assets/js/nav-mobile.js" defer></script>
    <script src="/assets/js/back-to-top.js" defer></script>
    <script src="/assets/js/nav-contrast.js" defer></script>
    <slot name="scripts" />
    {
      mapsApi && mapsKey && mapsCallback && (
        <script
          src="/assets/js/google-maps-boot.js"
          data-key={mapsKey}
          data-callback={mapsCallback}
        ></script>
      )
    }
  </body>
</html>
