---
interface Props {
  name: 'arrow-up' | 'plane';
  class?: string;
}

const { name, class: className = '' } = Astro.props;
---

{
  name === 'arrow-up' && (
    <svg
      class:list={['az-icon', 'az-icon--arrow-up', className]}
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false"
    >
      <path
        fill="currentColor"
        d="M7.41 15.41 12 10.83l4.59 4.58L18 14l-6-6-6 6z"
      />
    </svg>
  )
}
{
  name === 'plane' && (
    <svg
      class:list={['az-icon', 'az-icon--plane', className]}
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false"
    >
      {/* Material flight glyph — rotated 90° via .az-icon--plane so nose points right */}
      <path
        fill="currentColor"
        d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"
      />
    </svg>
  )
}
